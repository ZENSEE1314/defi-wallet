# Bot configuration (only used by `npm run bot`)

# RPC endpoint for trading bot (use a private RPC; public endpoints are rate-limited)
BOT_RPC_URL=https://eth.llamarpc.com
BOT_CHAIN_ID=1

# Hex private key for the bot's trading wallet (NEVER commit). Use a dedicated burner.
BOT_PRIVATE_KEY=

# Discovery: poll Dexscreener for tokens matching filters
DISCOVERY_MIN_LIQUIDITY_USD=50000
DISCOVERY_MIN_VOLUME_24H_USD=100000
DISCOVERY_MAX_AGE_HOURS=72

# Whale tracking: comma-separated addresses to follow
WHALE_ADDRESSES=

# Auto-trade rules
AUTO_BUY_USD=50
AUTO_SELL_PROFIT_PCT=50
AUTO_STOP_LOSS_PCT=20
SLIPPAGE_BPS=100
