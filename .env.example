# ───────── Bot core ─────────
# Use 56 for BSC (recommended for front-running — public mempool, cheap gas).
BOT_RPC_URL=https://bsc-dataseed.bnbchain.org
BOT_CHAIN_ID=56

# Hex private key for the bot's trading wallet. NEVER commit. Use a dedicated burner.
BOT_PRIVATE_KEY=

# Discovery filters (Dexscreener)
DISCOVERY_MIN_LIQUIDITY_USD=50000
DISCOVERY_MIN_VOLUME_24H_USD=100000
DISCOVERY_MAX_AGE_HOURS=72

# Whale tracking — comma-separated 0x addresses to follow
WHALE_ADDRESSES=

# Auto-trade rules
AUTO_BUY_USD=50
AUTO_SELL_PROFIT_PCT=50
AUTO_STOP_LOSS_PCT=20
SLIPPAGE_BPS=100

# Mirror exit — when a tracked whale sells a token we hold, dump ours too.
MIRROR_SELL=true

# ───────── Mempool front-runner (BSC / ETH only) ─────────
# Front-running needs WebSocket pending-tx subscription.
# Free options: Alchemy / QuickNode / Ankr (all support BSC + ETH).
# L2s (Arbitrum / Base / Optimism) have private sequencers — front-running is
# impossible there.
FRONTRUN_ENABLED=false
WSS_RPC_URL=
# Gas premium over the whale's tx, in basis points (5000 = +50%).
FRONTRUN_GAS_BOOST_BPS=5000
# Absolute gas ceiling so a gas war can't drain you.
FRONTRUN_MAX_GAS_GWEI=20
# Whale buy size range we react to (USD). Below = noise, above = coordinated dump.
FRONTRUN_MIN_BUY_USD=500
FRONTRUN_MAX_BUY_USD=50000
# Don't fire more often than this — protects against duplicate / chain reorgs.
FRONTRUN_COOLDOWN_MS=10000

# ───────── Top-volume momentum scanner (recommended for ~$100 capital) ─────────
# Pulls top-N pairs by 24h volume from Dexscreener every 30s, watches each
# pair's price history, fires on momentum spikes (1m + 5m thresholds), exits
# on TP / SL / time-stop. Designed for small capital where the front-runner
# would lose money to gas wars.
MOMENTUM_ENABLED=true
MOMENTUM_TOP_N=30
MOMENTUM_BUY_USD=8           # per-trade size — keep gas overhead reasonable
MOMENTUM_THRESH_1M_PCT=1.5   # require 1-min return >= this %
MOMENTUM_THRESH_5M_PCT=4     # require 5-min return >= this %
MOMENTUM_TP_PCT=10           # take profit at +10%
MOMENTUM_SL_PCT=3            # stop loss at -3%
MOMENTUM_TIME_STOP_MIN=30    # close any position after 30 minutes
MOMENTUM_MIN_LIQ_USD=100000  # skip illiquid pairs (rug risk)
MOMENTUM_MAX_POS=3           # max concurrent positions
MOMENTUM_POLL_MS=30000

# Paper mode = simulate trades without sending. ALWAYS start true.
PAPER_MODE=true
